{
  "name": "heliobond-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "load-test:smoke": "k6 run load-tests/scenarios/smoke.js",
    "load-test:average": "k6 run load-tests/scenarios/average-load.js",
    "load-test:stress": "k6 run load-tests/scenarios/stress.js",
    "load-test:spike": "k6 run load-tests/scenarios/spike.js",
    "load-test:graphql": "k6 run load-tests/scenarios/graphql.js",
    "release": "semantic-release"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@stellar/stellar-sdk": "^15.1.0",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "graphql": "^16.14.2",
    "graphql-http": "^1.22.4",
    "node-cron": "^4.2.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
